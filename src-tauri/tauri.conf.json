{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Needle",
  "version": "0.1.0",
  "identifier": "dev.somil.needle",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:7700",
    "beforeBuildCommand": "",
    "frontendDist": "frontend"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": {
      "../target/release/needle.exe": "needle.exe"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
