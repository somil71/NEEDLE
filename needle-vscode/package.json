{
  "name": "needle-search",
  "displayName": "Needle — Code Search & Graph",
  "description": "Local hybrid search + knowledge graph for your codebase. Offline, instant, no cloud.",
  "version": "0.1.0",
  "publisher": "needle-dev",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": ["search", "code", "graph", "offline", "semantic"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "needle",
          "title": "Needle",
          "icon": "media/needle.svg"
        }
      ]
    },
    "views": {
      "needle": [
        {
          "type": "webview",
          "id": "needle.search",
          "name": "Search"
        }
      ]
    },
    "commands": [
      {
        "command": "needle.showGraph",
        "title": "Needle: Show Knowledge Graph"
      },
      {
        "command": "needle.openInBrowser",
        "title": "Needle: Open in Browser"
      }
    ],
    "configuration": {
      "title": "Needle",
      "properties": {
        "needle.serverUrl": {
          "type": "string",
          "default": "http://localhost:7700",
          "description": "URL of the running needle serve instance"
        }
      }
    },
    "menus": {
      "commandPalette": [
        { "command": "needle.showGraph" },
        { "command": "needle.openInBrowser" }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
